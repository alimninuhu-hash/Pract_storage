<Window x:Class="WarehouseInventory.AddEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Товар"
        Height="725"
        Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F3F4F6">

    <Grid Margin="20">

        <Border Background="White"
                CornerRadius="14"
                Padding="25">

            <StackPanel>

                <TextBlock Text="Информация о товаре"
                           FontSize="26"
                           FontWeight="Bold"
                           Margin="0,0,0,25"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="Название"/>

                <TextBox x:Name="NameBox"
                         Height="40"
                         Margin="0,5,0,15"/>

                <TextBlock Text="Категория"/>

                <TextBox x:Name="CategoryBox"
                         Height="40"
                         Margin="0,5,0,15"/>

                <TextBlock Text="Количество"/>

                <TextBox x:Name="QuantityBox"
                         Height="40"
                         Margin="0,5,0,15"/>

                <TextBlock Text="Цена"/>

                <TextBox x:Name="PriceBox"
                         Height="40"
                         Margin="0,5,0,15"/>

                <TextBlock Text="Поставщик"/>

                <TextBox x:Name="SupplierBox"
                         Height="40"
                         Margin="0,5,0,15"/>

                <TextBlock Text="Дата поставки"/>

                <DatePicker x:Name="DeliveryDatePicker"
                            Height="40"
                            Margin="0,5,0,25"/>

                <Button Content="Сохранить"
                        Height="50"
                        FontSize="16"
                        FontWeight="Bold"
                        Background="#2563EB"
                        Foreground="White"
                        BorderThickness="0"
                        Click="Save_Click"/>

            </StackPanel>

        </Border>

    </Grid>

</Window>