<Window x:Class="WarehouseInventory.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Учет товаров на складе"
        Height="900"
        Width="1650"
        WindowStartupLocation="CenterScreen"
        Background="#F3F4F6">

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ЛЕВАЯ ПАНЕЛЬ -->

        <Border Grid.Column="0"
                Background="#1F2937">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Margin="20">

                    <!-- ЛОГО -->

                    <TextBlock Text="СКЛАД"
                               FontSize="34"
                               FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               Margin="0,20,0,40"/>

                    <!-- КНОПКИ -->

                    <Button x:Name="AddButton"
                            Content="Добавить товар"
                            Height="55"
                            Margin="0,0,0,15"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Background="#22C55E"
                            Foreground="White"
                            BorderThickness="0"
                            Click="Add_Click"/>

                    <Button x:Name="EditButton"
                            Content="Редактировать"
                            Height="55"
                            Margin="0,0,0,15"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Background="#0EA5E9"
                            Foreground="White"
                            BorderThickness="0"
                            Click="Edit_Click"/>

                    <Button x:Name="DeleteButton"
                            Content="Удалить товар"
                            Height="55"
                            Margin="0,0,0,30"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Background="#EF4444"
                            Foreground="White"
                            BorderThickness="0"
                            Click="Delete_Click"/>

                    <!-- ПОИСК -->

                    <TextBlock Text="Поиск"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="White"
                               Margin="0,0,0,10"/>

                    <TextBox x:Name="SearchBox"
                             Height="40"
                             Margin="0,0,0,25"
                             FontSize="14"
                             Padding="10"
                             TextChanged="SearchBox_TextChanged"/>

                    <!-- ФИЛЬТР -->

                    <TextBlock Text="Фильтр по категории"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="White"
                               Margin="0,0,0,10"/>

                    <ComboBox x:Name="CategoryFilterBox"
                              Height="40"
                              Margin="0,0,0,25"
                              FontSize="14"
                              SelectionChanged="CategoryFilterBox_SelectionChanged">

                        <ComboBoxItem Content="Все категории"/>
                        <ComboBoxItem Content="Техника"/>
                        <ComboBoxItem Content="Канцтовары"/>

                    </ComboBox>

                    <!-- СОРТИРОВКА -->

                    <TextBlock Text="Сортировка"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="White"
                               Margin="0,0,0,10"/>

                    <Button Content="Сортировать по алфавиту"
                            Height="45"
                            FontSize="15"
                            FontWeight="SemiBold"
                            Background="#374151"
                            Foreground="White"
                            BorderThickness="0"
                            Click="Sort_Click"/>

                </StackPanel>

                <!-- ВЫХОД -->

                <Button Grid.Row="1"
                        Content="Выйти"
                        Height="50"
                        Margin="20"
                        FontSize="15"
                        FontWeight="SemiBold"
                        Background="#374151"
                        Foreground="White"
                        BorderThickness="0"
                        Click="Exit_Click"/>

            </Grid>

        </Border>

        <!-- ПРАВАЯ ЧАСТЬ -->

        <Grid Grid.Column="1"
              Margin="15">

            <Grid.RowDefinitions>
                <RowDefinition Height="140"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- СТАТИСТИКА -->

            <Grid Grid.Row="0"
                  Margin="0,0,0,15">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ВСЕГО ТОВАРОВ -->

                <Border Grid.Column="0"
                        Background="White"
                        CornerRadius="14"
                        Margin="136,0,224,0"
                        Padding="20" Grid.ColumnSpan="2">

                    <StackPanel>

                        <TextBlock Text="Всего товаров"
                                   FontSize="16"
                                   Foreground="#6B7280"/>

                        <TextBlock x:Name="TotalProductsText"
                                   Text="0"
                                   FontSize="34"
                                   FontWeight="Bold"
                                   Margin="0,10,0,0"/>

                    </StackPanel>

                </Border>

                <!-- ОБЩЕЕ КОЛИЧЕСТВО -->

                <Border Grid.Column="1"
                        Background="White"
                        CornerRadius="14"
                        Margin="173,0,181,0"
                        Padding="20" Grid.ColumnSpan="2">

                    <StackPanel>

                        <TextBlock Text="Единиц товара"
                                   FontSize="16"
                                   Foreground="#6B7280"/>

                        <TextBlock x:Name="TotalQuantityText"
                                   Text="0"
                                   FontSize="34"
                                   FontWeight="Bold"
                                   Margin="0,10,0,0"/>

                    </StackPanel>

                </Border>

                <!-- ОБЩАЯ СТОИМОСТЬ -->

                <Border Grid.Column="2"
                        Background="White"
                        CornerRadius="14"
                        Margin="209,0,151,0"
                        Padding="20" Grid.ColumnSpan="2">

                    <StackPanel>

                        <TextBlock Text="Стоимость склада"
                                   FontSize="16"
                                   Foreground="#6B7280"/>

                        <TextBlock x:Name="TotalPriceText"
                                   Text="0 ₽"
                                   FontSize="34"
                                   FontWeight="Bold"
                                   Foreground="#16A34A"
                                   Margin="0,10,0,0"/>

                    </StackPanel>

                </Border>



            </Grid>

            <!-- ТАБЛИЦА -->

            <Border Grid.Row="1"
                    Background="White"
                    CornerRadius="14"
                    Padding="15">

                <DataGrid x:Name="ProductsGrid"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          FontSize="16"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          BorderThickness="0"
                          RowHeight="55">

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="ID"
                                            Binding="{Binding Id}"
                                            Width="70"/>

                        <DataGridTextColumn Header="Название"
                                            Binding="{Binding Name}"
                                            Width="220"/>

                        <DataGridTextColumn Header="Категория"
                                            Binding="{Binding Category}"
                                            Width="180"/>

                        <DataGridTextColumn Header="Количество"
                                            Binding="{Binding Quantity}"
                                            Width="140"/>

                        <DataGridTextColumn Header="Цена"
                                            Binding="{Binding Price}"
                                            Width="160"/>

                        <DataGridTextColumn Header="Общая стоимость"
                                            Binding="{Binding TotalPrice}"
                                            Width="220"/>

                        <DataGridTextColumn Header="Поставщик"
                                            Binding="{Binding Supplier}"
                                            Width="180"/>

                        <DataGridTextColumn Header="Дата поставки"
                                            Binding="{Binding DeliveryDate}"
                                            Width="180"/>

                    </DataGrid.Columns>

                </DataGrid>

            </Border>

        </Grid>

    </Grid>

</Window>
